{
  "name": "aiops-agent-local-cockpit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local operator-facing AIOps cockpit backed by Codex CLI and MCP servers.",
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "tsx watch src/server/index.ts",
    "dev:web": "vite --host 127.0.0.1",
    "build": "npm run typecheck && rm -rf dist && vite build && tsc -p tsconfig.server.json",
    "start": "node dist/src/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "setup:mcp": "bash scripts/setup-mcp.sh",
    "smoke:llm": "tsx scripts/smoke-llm.ts",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "11.2.0",
    "@fastify/static": "9.1.3",
    "@modelcontextprotocol/sdk": "1.29.0",
    "better-sqlite3": "11.10.0",
    "concurrently": "9.1.2",
    "fastify": "5.8.5",
    "lucide-react": "0.468.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "3.25.76",
    "zod-to-json-schema": "3.24.6"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@types/better-sqlite3": "7.6.12",
    "@types/node": "22.10.2",
    "@types/react": "18.3.17",
    "@types/react-dom": "18.3.5",
    "@vitejs/plugin-react": "4.3.4",
    "jsdom": "25.0.1",
    "tsx": "4.21.0",
    "typescript": "5.7.2",
    "vite": "5.4.21",
    "vitest": "2.1.9"
  },
  "engines": {
    "node": ">=18.19"
  }
}
