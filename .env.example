# Copy this file to .env and fill in the provider/API key you want to use.

# ── LLM ──────────────────────────────────────────────────────────────
LLM_PROVIDER=openrouter
TEMPERATURE=0.1
LLM_MAX_OUTPUT_TOKENS=4096
LLM_REQUEST_TIMEOUT_SEC=120

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=AIOps Agent

# ── Kubernetes ───────────────────────────────────────────────────────
K8S_CONTEXT=
K8S_DEFAULT_NAMESPACE=default
K8S_CLI_ALLOW_ALL_READ=true
K8S_CLI_ALLOW_ALL_WRITE=false
K8S_ALLOWED_NAMESPACES=
K8S_BLOCKED_NAMESPACES=

# ── AWS ──────────────────────────────────────────────────────────────
AWS_CLI_ENABLED=true
AWS_CLI_ALLOW_ALL_READ=true
AWS_CLI_ALLOW_ALL_WRITE=false
AWS_CLI_PROFILE=
AWS_CLI_DEFAULT_REGION=
AWS_ALLOWED_REGIONS=
AWS_BLOCKED_REGIONS=
CREATE_STATE_DIR=runtime_state
CREATE_WAIT_POLL_INTERVAL_SEC=10
CREATE_WAIT_TIMEOUT_SEC=1800
CREATE_STREAM_EVENT_POLL_INTERVAL_SEC=5
CREATE_TAG_OWNER=aiops-agent
CREATE_TAG_INTENT_PREFIX=aiops
CREATE_COST_ESTIMATION_ENABLED=true

# ── Safety ───────────────────────────────────────────────────────────
COMMAND_SAFETY_POSTURE=approval_required

# ── Tracing ──────────────────────────────────────────────────────────
TRACE_ENABLED=true
TRACE_DIR=traces

# ── Chat ─────────────────────────────────────────────────────────────
MAX_CHAT_HISTORY_MESSAGES=14

# ── Agent ────────────────────────────────────────────────────────────
DIAGNOSE_MAX_STEPS=15
DIAGNOSE_CHECKPOINT_STEP=7
LOOKUP_MAX_STEPS=8
LOOKUP_CHECKPOINT_STEP=3
EXPLAIN_MAX_STEPS=10
ACTION_MAX_STEPS=8
